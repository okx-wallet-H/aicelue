# OKX API 配置
OKX_PROFILE=live
OKX_USE_DEMO=false
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# OKX CLI 可执行文件路径（默认 /usr/bin/okx，可按需覆盖）
OKX_CLI_PATH=/usr/bin/okx

# 交易开关：必须显式设置为 true 才允许 --execute 真实下单
# 强烈建议先在 Demo 模式（OKX_USE_DEMO=true）下验证后再启用
TRADING_ENABLED=false

# LLM 配置（通过 OpenAI 兼容接口调用，例如通义千问）
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_API_KEY=
LLM_MODEL=qwen-plus-latest
LLM_ENABLED=true
LLM_TIMEOUT_SECONDS=30

# 风控参数（可选覆盖）
# MAX_TRADE_RISK_PCT=0.015    # 单笔最大风险比例（默认 1.5%）
# TOTAL_MARGIN_CAP_RATIO=0.60 # 总保证金上限比例（默认 60%）
# MAX_LEVERAGE_CAP=15          # 杠杆上限（默认 15x）
